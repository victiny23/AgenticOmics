# AgenticOmics Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# Admin User Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password-here
ADMIN_EMAIL=admin@yourdomain.com

# Demo User Credentials
DEMO_USERNAME=demo
DEMO_PASSWORD=your-secure-demo-password-here
DEMO_EMAIL=demo@yourdomain.com

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/agenticomics
DATABASE_USERNAME=agenticomics
DATABASE_PASSWORD=your-secure-database-password-here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-secure-redis-password-here

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/agenticomics
MONGODB_USERNAME=agenticomics
MONGODB_PASSWORD=your-secure-mongodb-password-here

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=agenticomics
RABBITMQ_PASSWORD=your-secure-rabbitmq-password-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
JWT_EXPIRATION=86400000

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password-here

# File Upload Configuration
FILE_UPLOAD_PATH=./uploads
FILE_MAX_SIZE=10485760

# Email Configuration (if needed)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-email@domain.com
SMTP_PASSWORD=your-email-password-here

# Security Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-here
CORS_ALLOWED_ORIGINS=http://localhost:12000,http://localhost:3000

# Development Configuration
SPRING_PROFILES_ACTIVE=dev
DEBUG_MODE=false 