# AgenticOmics Platform Environment Variables
# Copy this file to .env and update the values

# Environment
NODE_ENV=development
SPRING_PROFILES_ACTIVE=development

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/agenticomics
DATABASE_USERNAME=agenticomics
DATABASE_PASSWORD=agenticomics_password

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017/agenticomics
MONGODB_USERNAME=agenticomics
MONGODB_PASSWORD=agenticomics_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=agenticomics
RABBITMQ_PASSWORD=agenticomics_password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# LangChain Configuration
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_TRACING_V2=true

# File Storage Configuration
UPLOAD_PATH=/app/data/uploads
MAX_FILE_SIZE=1073741824  # 1GB in bytes
ALLOWED_FILE_TYPES=.fastq,.fq,.bam,.sam,.vcf,.csv,.tsv,.xlsx,.h5,.h5ad

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@agenticomics.com

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080
REACT_APP_UPLOAD_MAX_SIZE=1073741824

# Python Services Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_PASSWORD=admin

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=agenticomics-data

# Google Cloud (Optional)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCS_BUCKET_NAME=agenticomics-data

# Azure (Optional)
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_CONTAINER_NAME=agenticomics-data

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development Configuration
DEBUG=true
HOT_RELOAD=true

# Production Configuration (uncomment for production)
# SSL_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem